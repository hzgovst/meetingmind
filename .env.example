# ==============================================================
# OPTION A: Free Tier (limited quota)
# Get your key at: https://aistudio.google.com/app/apikey
# ==============================================================
# GEMINI_API_KEY=your_gemini_api_key_here

# ==============================================================
# OPTION B: Paid Tier via Vertex AI (recommended, uses GCP billing)
# 1. Run: gcloud auth application-default login
# 2. Run: gcloud auth application-default set-quota-project YOUR_PROJECT_ID
# 3. Set your project ID below
# ==============================================================
GCP_PROJECT_ID=your_gcp_project_id
GCP_LOCATION=us-central1

# ==============================================================
# Model Configuration (works with both options)
# ==============================================================
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_MODEL=gemini-2.0-flash-lite
MAX_RPM=30
AUDIO_CHUNK_SECONDS=6
DATABASE_URL=sqlite+aiosqlite:////app/data/meetingmind.db
MAX_FILE_SIZE_MB=10
