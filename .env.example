# MeetingMind AI - Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# =============================================================
# REQUIRED: Google Gemini API Key (FREE tier - no credit card)
# Get yours at: https://aistudio.google.com/app/apikey
# =============================================================
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================
# OPTIONAL: Model Configuration (defaults are set below)
# =============================================================
# Primary model - Gemini 2.0 Flash (15 RPM free tier)
GEMINI_MODEL=gemini-2.0-flash-exp

# Fallback model - Gemini 2.0 Flash Lite (30 RPM free tier)
GEMINI_FALLBACK_MODEL=gemini-2.0-flash-lite

# Maximum requests per minute (stay safely under 15 RPM limit)
MAX_RPM=14

# Audio chunk processing duration in seconds
AUDIO_CHUNK_SECONDS=12

# Database URL (SQLite - zero config)
DATABASE_URL=sqlite+aiosqlite:////app/data/meetingmind.db

# Max file upload size in MB
MAX_FILE_SIZE_MB=10
